{
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.vcxproj": "xml",
        "*.slnx": "xml"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.vs": true,
        "**/x64": false,
        "**/Debug": false,
        "**/Release": false
    },
    "C_Cpp.default.configurationProvider": "ms-vscode.cpptools",
    "C_Cpp.default.intelliSenseMode": "windows-msvc-x64",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.autocomplete": "default",
    "C_Cpp.formatting": "vcFormat",
    "C_Cpp.vcFormat.indentBraces": false,
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "newLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "newLine",
    "C_Cpp.vcFormat.space.beforeComma": false,
    "C_Cpp.vcFormat.space.afterComma": true,
    "C_Cpp.vcFormat.space.aroundAssignmentOperator": true,
    "C_Cpp.vcFormat.space.beforeOpeningParenthesis.functionCall": false,
    "C_Cpp.vcFormat.space.beforeOpeningParenthesis.functionDefinition": false,
    "C_Cpp.vcFormat.space.beforeOpeningParenthesis.controlStatement": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/x64": true
    },
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "terminal.integrated.defaultProfile.windows": "Developer Command Prompt for VS 2026",
    "terminal.integrated.profiles.windows": {
        "Developer Command Prompt for VS 2026": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [
                "/k",
                "\"C:\\Program Files\\Microsoft Visual Studio\\18\\Community\\Common7\\Tools\\VsDevCmd.bat\"",
                "-arch=amd64",
                "-host_arch=amd64"
            ],
            "icon": "terminal-cmd"
        }
    },
    "cmake.configureOnOpen": false,
    "cmake.showOptionsMismatchNotification": false
}