{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试 Demo (x64 Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/x64/Debug/Demo.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Demo",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "build-x64-debug",
            "symbolSearchPath": "${workspaceFolder}/x64/Debug"
        },
        {
            "name": "调试 Demo (x64 Release)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/x64/Release/Demo.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Demo",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "build-x64-release",
            "symbolSearchPath": "${workspaceFolder}/x64/Release"
        },
        {
            "name": "附加到进程",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "symbolSearchPath": "${workspaceFolder}/x64/Debug"
        }
    ]
}